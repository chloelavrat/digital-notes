# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:dev_password@localhost:5432/digital_notes

# ── GCS emulator ────────────────────────────────────────────────────
# Points the GCS client library at the local fake-gcs-server
STORAGE_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET=digital-notes-local

# ── Google OAuth ─────────────────────────────────────────────────────
# Create an OAuth 2.0 client at: https://console.cloud.google.com/apis/credentials
# Authorised JS origins: http://localhost:5173
# Authorised redirect URIs: http://localhost:5173
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Session ──────────────────────────────────────────────────────────
SESSION_SECRET=local-dev-secret-at-least-32-chars

# ── Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth (legacy .env gate — leave AUTH_ENABLED=false when using Google OAuth) ──
AUTH_ENABLED=false
