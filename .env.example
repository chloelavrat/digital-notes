ANTHROPIC_API_KEY=sk-ant-your-key-here
PORT=3001

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:dev_password@localhost:5432/digital_notes

# ── Google Cloud Storage ─────────────────────────────────────────────
GCS_BUCKET=digital-notes-local
# Set when using local fake-gcs-server (leave empty in production)
# STORAGE_EMULATOR_HOST=http://localhost:4443

# ── Google OAuth ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Session ──────────────────────────────────────────────────────────
SESSION_SECRET=a-long-random-string-change-in-production

# Optional login protection — set AUTH_ENABLED=true to activate
AUTH_ENABLED=false

# Multiple users: AUTH_USERS=alice:pass1,bob:pass2
AUTH_USERS=admin:change-me

# Or legacy single-user format (ignored if AUTH_USERS is set)
# AUTH_USERNAME=admin
# AUTH_PASSWORD=change-me

# Secret used to sign session cookies — change this in production
AUTH_SECRET=a-long-random-secret-string
