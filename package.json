  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"vite,api\" \"vite\" \"PORT=3001 node --env-file-if-exists=.env --watch server.js\"",
    "dev:client": "vite",
    "dev:server": "PORT=3001 node --env-file-if-exists=.env --watch server.js",
    "build": "vite build",
    "start": "node server.js",
    "generate:icons": "node scripts/generate-icons.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
